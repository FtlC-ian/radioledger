{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.radioledger.desktop",
  "build": {
    "frontendDist": "../src/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "RadioLedger",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": true,
        "visible": true
      }
    ],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png"
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data:; connect-src 'self' https://radioledger.app https://*.radioledger.app http://127.0.0.1:*; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Ham radio logbook desktop client",
    "longDescription": "RadioLedger desktop client \u2014 WSJT-X integration, LoTW signing bridge, offline QSO queue",
    "macOS": {
      "entitlements": null,
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-dev",
          "libssl-dev",
          "libsecret-1-dev"
        ]
      }
    }
  },
  "plugins": {
    "single-instance": null,
    "autostart": null
  }
}
