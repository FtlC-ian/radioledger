{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "types": ["@wdio/globals/types", "node", "mocha", "vitest/globals"]
  },
  "include": ["src/**/*", "wdio.conf.ts", "test/**/*"],
  "exclude": ["node_modules", "dist", "src-tauri"]
}
