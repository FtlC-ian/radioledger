# RadioLedger — Environment Variables
#
# DO NOT commit .env to source control. This file is the template.
# Run ./init.sh to generate .env with random secrets.
#
# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=radioledger
POSTGRES_PASSWORD=REPLACE_WITH_GENERATED_PASSWORD
POSTGRES_DB=radioledger

# Official postgis/postgis images currently publish amd64 manifests only.
# Apple Silicon/arm64 hosts need Docker emulation enabled or a custom multi-arch
# PostGIS image supplied here.
POSTGIS_IMAGE=postgis/postgis:17-3.5
POSTGIS_PLATFORM=linux/amd64

# ── Master Encryption Key ──────────────────────────────────────────────────────
# AES-256-GCM master key for credential encryption (QRZ, eQSL, ClubLog keys).
# IMPORTANT: Back up this key separately from your database backup.
# If you lose it, all stored external service credentials are unrecoverable.
# The server refuses to start if this is empty.
RADIOLEDGER_MASTER_KEY=REPLACE_WITH_GENERATED_KEY

# ── API Server ─────────────────────────────────────────────────────────────────
API_PORT=8080

# Comma-separated list of allowed CORS origins.
# For self-hosted behind a reverse proxy, set to your actual domain.
# Example: https://radioledger.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Default bind is localhost-only because the quickstart uses development auth.
# Do not set BIND_ADDRESS=0.0.0.0 until APP_ENV=production and AUTH_MODE=zitadel
# are configured.
BIND_ADDRESS=127.0.0.1

# Application environment: development | staging | production
APP_ENV=development

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info

# Auth mode. The default self-host quickstart uses development auth and binds
# published ports to localhost only. For a public production deployment, set
# APP_ENV=production, AUTH_MODE=zitadel, configure ZITADEL_URL, start the
# zitadel profile or use an external IdP, then intentionally set BIND_ADDRESS.
AUTH_MODE=dev

# ── Monitoring ────────────────────────────────────────────────────────────────
# Prometheus and Grafana start with `docker compose --profile monitoring up -d`.
# Grafana is bound to 127.0.0.1:3001 (localhost only).
# Set a strong password here — init.sh generates one automatically.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_GENERATED_GRAFANA_PASSWORD

# ── Development overrides (docker-compose.dev.yml) ────────────────────────────
# pgAdmin credentials (dev only — not used in production stack)
PGADMIN_EMAIL=admin@radioledger.local
PGADMIN_PASSWORD=admin
