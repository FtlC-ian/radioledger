{
  "name": "radioledger-web",
  "version": "0.0.1",
  "description": "RadioLedger Quasar web UI skeleton",
  "productName": "RadioLedger Web",
  "author": "RadioLedger Contributors",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{js,ts,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:unit": "vitest run",
    "test:e2e:docs": "playwright test --config playwright.docs.config.ts",
    "dev": "quasar dev",
    "build": "quasar build",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.4",
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "core-js": "^3.31.1",
    "dompurify": "^3.4.12",
    "marked": "^17.0.4",
    "pinia": "^3.0.4",
    "quasar": "^2.16.0",
    "vue": "^3.5.22",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@playwright/test": "^1.58.2",
    "@quasar/app-webpack": "^4.1.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.2",
    "babel-loader": "^9.2.1",
    "css-loader": "^7.1.4",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^10.4.0",
    "eslint-webpack-plugin": "^4.2.0",
    "globals": "^16.4.0",
    "happy-dom": "^16.8.1",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.3.3",
    "sass-loader": "^16.0.8",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "url-loader": "^4.1.1",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^10.2.0",
    "vue-loader": "^17.4.2",
    "vue-style-loader": "^4.1.3"
  },
  "browserslist": [
    "last 10 Chrome versions",
    "last 10 Firefox versions",
    "last 4 Edge versions",
    "last 7 Safari versions",
    "last 8 Android versions",
    "last 8 ChromeAndroid versions",
    "last 8 FirefoxAndroid versions",
    "last 10 iOS versions",
    "last 5 Opera versions"
  ],
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20 || ^18",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1",
    "pnpm": ">= 10.0.0"
  }
